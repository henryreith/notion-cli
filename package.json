{
  "name": "notion-agent-cli",
  "version": "0.1.2",
  "description": "Zero-overhead CLI for the Notion API — for AI agents, scripts, and automation",
  "type": "module",
  "bin": {
    "notion": "dist/cli.js",
    "notion-agent": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "version": "node scripts/sync-version.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "notion",
    "cli",
    "api",
    "agent",
    "automation"
  ],
  "author": "Henry Reith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henryreith/notion-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@notionhq/client": "^5.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
